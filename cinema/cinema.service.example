[Unit]
Description=Cloud Cinema
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/cinema
Environment=AUTH_BASE=/opt/auth
Environment=CINEMA_BASE_DIR=/opt/cinema
ExecStart=/opt/cinema/.venv/bin/uvicorn app:app --host 127.0.0.1 --port 8890 --workers 1
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
