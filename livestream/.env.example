LIVESTREAM_BASE_DIR=/opt/livestream
LIVESTREAM_DATA_DIR=/opt/livestream/data
LIVESTREAM_SECRET_KEY=change-this-random-secret
LIVESTREAM_HOST=127.0.0.1
LIVESTREAM_PORT=8888
LIVESTREAM_MAX_STORAGE_GB=5
AUTH_BASE=/opt/auth
SRS_HOST=127.0.0.1
SRS_RTMP_PORT=1935
SRS_HTTP_PORT=8090
SRS_API_PORT=1985
# Optional advanced overrides. Leave unset to derive from SRS_HOST and ports.
# SRS_API_BASE=http://127.0.0.1:1985/api/v1
# SRS_RTMP_INPUT_URL=rtmp://127.0.0.1:1935/live/stream
# SRS_RTMP_SMOOTH_URL=rtmp://127.0.0.1:1935/live/stream_smooth
