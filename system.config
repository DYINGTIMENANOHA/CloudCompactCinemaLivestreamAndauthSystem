# CloudCompactCinemaLivestreamAndauthSystem central config
#
# Format: KEY=value
# Keep values shell-safe: no spaces around "=", quote values only when necessary.
# Runtime priority is:
#   1. real environment variables
#   2. this system.config file
#   3. code defaults

# ---------------------------------------------------------------------------
# Public access examples
# ---------------------------------------------------------------------------

# Public domain used in generated links and nginx examples.
PUBLIC_DOMAIN=YOUR_DOMAIN

# Public HTTPS port. Use 443 for normal HTTPS, or 8443 if your nginx listens there.
PUBLIC_HTTPS_PORT=443

# Public RTMP port used by OBS/publish clients.
PUBLIC_RTMP_PORT=1935


# ---------------------------------------------------------------------------
# Auth
# ---------------------------------------------------------------------------

# Auth install/runtime directory. Cinema and livestream must be able to read this.
AUTH_BASE=/opt/auth

# SQLite token database managed by auth/manage_token.sh.
AUTH_TOKENS_DB=/opt/auth/data/tokens.db

# Admin/publish key directory. Files are live_admin.key, test_admin.key, cinema_admin.key.
AUTH_KEYS_DIR=/opt/auth/keys

# Rooms known by auth. "cinema" is the cloud cinema room; live/test are livestream rooms.
AUTH_VALID_ROOMS=live,test,chutianshu,cinema


# ---------------------------------------------------------------------------
# Cinema service
# ---------------------------------------------------------------------------

# Cinema install/runtime directory.
CINEMA_BASE_DIR=/opt/cinema

# Host and port for the internal FastAPI service. Nginx should proxy to this.
CINEMA_HOST=127.0.0.1
CINEMA_PORT=8890

# Runtime storage paths.
CINEMA_DATA_DIR=/opt/cinema/data
CINEMA_DB_PATH=/opt/cinema/data/cinema.db
CINEMA_LOG_DIR=/opt/cinema/logs
CINEMA_UPLOADS_DIR=/opt/cinema/uploads
CINEMA_VIDEOS_DIR=/opt/cinema/videos
CINEMA_COVERS_DIR=/opt/cinema/videos_covers

# Static/template paths.
CINEMA_STATIC_DIR=/opt/cinema/static
CINEMA_TEMPLATES_DIR=/opt/cinema/templates

# Media tools used by cinema upload/transcode logic.
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe


# ---------------------------------------------------------------------------
# Livestream Flask service
# ---------------------------------------------------------------------------

# Livestream install/runtime directory.
LIVESTREAM_BASE_DIR=/opt/livestream

# Host and port for the internal Flask service. Nginx and SRS on_publish use this.
LIVESTREAM_HOST=127.0.0.1
LIVESTREAM_PORT=8888

# Livestream runtime data.
LIVESTREAM_DATA_DIR=/opt/livestream/data
LIVESTREAM_LOG_DIR=/opt/livestream/logs
LIVESTREAM_MAX_STORAGE_GB=5
LIVESTREAM_SECRET_KEY=change-this-random-secret
LIVESTREAM_CORS_ORIGINS=*


# ---------------------------------------------------------------------------
# SRS media server
# ---------------------------------------------------------------------------

# Host used by livestream Python code to reach SRS.
# Keep 127.0.0.1 when SRS and livestream run on the same server.
SRS_HOST=127.0.0.1

# RTMP ingest port. OBS pushes to rtmp://YOUR_DOMAIN:SRS_RTMP_PORT/live/stream?key=...
SRS_RTMP_PORT=1935

# HTTP-FLV/HLS playback port. Nginx can proxy /live/ and /test/ to this.
SRS_HTTP_PORT=8090

# SRS HTTP API port. Usually keep this private to localhost or firewall-restricted.
SRS_API_PORT=1985

# Livestream derives these URLs from SRS_HOST/SRS_*_PORT automatically:
#   SRS API base:      http://SRS_HOST:SRS_API_PORT/api/v1
#   Smooth input:      rtmp://SRS_HOST:SRS_RTMP_PORT/live/stream
#   Smooth output:     rtmp://SRS_HOST:SRS_RTMP_PORT/live/stream_smooth
# Advanced users can still override SRS_API_BASE, SRS_RTMP_INPUT_URL, or
# SRS_RTMP_SMOOTH_URL as real environment variables in systemd/shell.


# ---------------------------------------------------------------------------
# Nginx reference ports
# ---------------------------------------------------------------------------

# Nginx is not installed/configured by the project deploy scripts.
# These values document the intended public ports for your nginx config.
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
